class Solution {
    public int pivotIndex(int[] nums) {
        int[] arr=new int[nums.length];
        for(int i=0;i<nums.length;i++)
           arr[i]=nums[i];
        for(int i=nums.length-2;i>=0;i--)
           arr[i]+=arr[i+1];
        if(nums[0]==arr[0])
           return 0;
        for(int i=1;i<nums.length;i++)
        {
            nums[i]+=nums[i-1];
            if(nums[i]==arr[i])
               return i;
        }
        return -1;
    }
}