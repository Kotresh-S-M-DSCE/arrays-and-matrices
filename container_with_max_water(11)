class Solution {
    public int maxArea(int[] height) {
        int i=0,j=height.length-1,area=0,temp;
        while(i<=j)
        {
            if(height[i]<height[j])
               temp=height[i];
            else
               temp=height[j];
            if(area<temp*(j-i))
                area=temp*(j-i);
            if(height[i]<height[j])
               i++;
            else
               j--;
        }
        return area;
    }
}