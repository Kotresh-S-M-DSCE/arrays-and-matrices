class Solution {
    public long maxTotalValue(int[] nums, int k) {
        long min=1000000000,max=-1;
        for(int i=0;i<nums.length;i++)
        {
            if(nums[i]<min)
               min=nums[i];
            if(nums[i]>max)
               max=nums[i];
        }
        return (max-min)*k;
    }
}