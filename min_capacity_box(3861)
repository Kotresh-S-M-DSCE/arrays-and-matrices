class Solution {
    public int minimumIndex(int[] capacity, int itemSize) {
        int small=200,index=0;
        for(int i=0;i<capacity.length;i++)
        {
            if((capacity[i]-itemSize<small)&&(capacity[i]-itemSize)>=0)
            {
               small=capacity[i]-itemSize;
               index=i;
            }
        }
        if(small==200)
          return -1;
        else 
          return index;
    }
}