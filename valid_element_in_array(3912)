class Solution {
    public List<Integer> findValidElements(int[] nums) {
        int[] arr=new int[nums.length];
        int[] arr2=new int[nums.length];
        List<Integer> ret=new ArrayList<>();
        ret.add(nums[0]);
        if(nums.length==1)
           return ret;
        arr[nums.length-1]=nums[nums.length-1];
        for(int i=nums.length-2;i>=0;i--)
        {
            if(nums[i]>arr[i+1])
               arr[i]=nums[i];
            else
               arr[i]=arr[i+1];
        }
        arr2[0]=nums[0];
        for(int i=1;i<nums.length-1;i++)
        {
            if(arr2[i-1]>nums[i])
               arr2[i]=arr2[i-1];
            else 
               arr2[i]=nums[i];
        }
        for(int i=1;i<nums.length-1;i++)
        {
            if(nums[i]>arr2[i-1]||nums[i]>arr[i+1])
               ret.add(nums[i]);
        }
        ret.add(nums[nums.length-1]);
        return ret;
    }
}