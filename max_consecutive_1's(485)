class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int i=0,max=0;
        while(i<nums.length)
        {
            int count=0;
            if(nums[i]==1)
            {
                while(i<nums.length&&nums[i]==1)
                {
                    count++;
                    i++;
                }
                if(count>max)
                   max=count;
            }
            else
               i++;
        }
        return max;
    }
}