class Solution {
    public int majorityElement(int[] nums) {
        int num=nums[0],count=1;
        for(int i=1;i<nums.length-1;i++)
        {
            if(num==nums[i])
               count+=1;
            else
               count-=1;
            if(count==0)
            {
                num=nums[i+1];
                i++;
                count=1;
            }
        }
        return num;
    }
}
