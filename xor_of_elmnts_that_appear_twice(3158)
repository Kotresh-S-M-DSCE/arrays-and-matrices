class Solution {
    public int duplicateNumbersXOR(int[] nums) {
       Set<Integer> set=new HashSet<>();
       int ret=0;
       for(int i=0;i<nums.length;i++)
       {
          if(!set.contains(nums[i]))
            set.add(nums[i]);
          else
            ret^=nums[i];
       }
       return ret;
    }
}