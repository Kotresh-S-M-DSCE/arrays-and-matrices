class Solution {
    public long dividePlayers(int[] skill) {
        Arrays.sort(skill);
        long ret=skill[0]*skill[skill.length-1];
        int temp=skill[0]+skill[skill.length-1],n=skill.length-2;
        for(int i=1;i<skill.length/2;i++)
        {
            if(temp!=(skill[i]+skill[n]))
               return -1;
            ret+=skill[i]*skill[n];
            n--;
        }
        return ret;
    }
}