class Solution {
    public int[] separateDigits(int[] nums) {
        List<Integer> list=new ArrayList<>();
        for(int i=nums.length-1;i>=0;i--)
        {
            while(nums[i]>0)
            {
                list.add(nums[i]%10);
                nums[i]/=10;
            }
        }
        int[] ret=new int[list.size()];
        int n=0;
        for(int i=list.size()-1;i>=0;i--)
           ret[n++]=list.get(i);
        return ret;
    }
}