class Solution {
    public int getMinDistance(int[] nums, int target, int start) {
        int i=start,j=start;
        while((i!=0||j!=nums.length-1)&&(nums[i]!=target&&nums[j]!=target))
        {
            if(i==0)
               j++;
            else if(j==nums.length-1)
               i--;
            else
            {
                j++;
                i--;
            }
        }
        if(nums[i]==target)
           return (start-i);
        return (j-start);
    }
}