class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {
        for(int j=y;j<(y+k);j++)
        {
            int n=k+x-1;
            for(int i=x;i<(x+k/2);i++)
            {
                int temp=grid[i][j];
                grid[i][j]=grid[n][j];
                grid[n][j]=temp;
                n--;
            }
        }
        return grid;
    }
}