class Solution {
    public int[] scoreValidator(String[] events) {
        int run=0,count=0;
        int[] ret=new int[2];
        for(int i=0;i<events.length&&count<10;i++)
        {
            if(events[i].equals("W"))
               count++;
            else if(events[i].equals("WD")||events[i].equals("NB"))
               run++;
            else
                run+=events[i].charAt(0)-'0';
        }
        ret[0]=run;
        ret[1]=count;
        return ret;
    }
}