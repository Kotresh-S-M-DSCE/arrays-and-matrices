class Solution {
    public int minStartValue(int[] nums) {
        int min=nums[0];
        if(nums.length==1&&nums[0]<1)
           return (-nums[0])+1;
        for(int i=1;i<nums.length;i++)
        {
            nums[i]=nums[i]+nums[i-1];
            if(nums[i]<min)
               min=nums[i];
        }
        if(min>0)
           return 1;
        min=-min;
        return min+1;
    }
}