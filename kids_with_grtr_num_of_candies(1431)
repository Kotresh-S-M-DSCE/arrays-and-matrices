class Solution {
    public List<Boolean> kidsWithCandies(int[] candies, int extraCandies) {
        int max=0;
        for(int i=0;i<candies.length;i++)
        {
            if(max<candies[i])
               max=candies[i];
        }
        List<Boolean> ret=new ArrayList<>();
        for(int i=0;i<candies.length;i++)
        {
            if(extraCandies+candies[i]>=max)
               ret.add(true);
            else
               ret.add(false);
        }
        return ret;
    }
}